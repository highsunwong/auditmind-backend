datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Audit {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  status    String   @default("pending")
  progress  Int      @default(0)
  logs      Json?
  createdAt DateTime @default(now())
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
}